# --- Database ---
# Either supply the discrete DB_* vars below (dev convenience) OR a full
# DATABASE_URL (production). The code prefers DATABASE_URL when set.
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=
DATABASE_URL=
# Optional read-replica DSN. When unset, reads go to the primary.
READ_DATABASE_URL=

# --- Server ---
# API listen port (defaults to 8080 if unset).
PORT=
# Set to "true" to run the cron scheduler in-process with the API
# (dev convenience). In production the scheduler runs as its own pod.
EMBED_SCHEDULER=
APP_ENV=development

# --- Auth / identity ---
# HMAC secret for signing JWTs. Must be set in every environment.
API_SECRET=
# Seed-admin credentials — only used on first boot to create the admin.
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Salt for the anonymous-device fingerprint hash (IP + UA → device ID).
ANON_DEVICE_SALT=

# --- Proxy / origins ---
# Local dev: where to proxy unmatched routes (typically the React dev
# server at http://localhost:3000).
FRONTEND_PROXY=
# Public origin URLs used to build absolute share links.
PUBLIC_ORIGIN=
FRONTEND_ORIGIN=

# --- Redis / Valkey (pub-sub + vote-delta cache) ---
# Prefer a single URL; REDIS_ADDR + USERNAME + PASSWORD is the fallback
# for providers that hand those out separately.
REDIS_URL=
VALKEY_URL=
REDIS_ADDR=
REDIS_USERNAME=
REDIS_PASSWORD=

# --- AWS / S3 ---
S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional — only needed when using temporary credentials (STS / SSO).
AWS_SESSION_TOKEN=

# --- Email (SendGrid) ---
SENDGRID_API_KEY=
SENDGRID_FROM=

# --- Web Push (VAPID) ---
# Generate a keypair with: go run ./cmd/generate_vapid
# The public key is safe to share; the private key MUST stay secret.
# A keypair rotation invalidates every existing browser subscription,
# so only rotate on key compromise.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# --- Apple Push Notification service (APNS) ---
# Token-based auth via a .p8 EC private key from the Apple Developer
# portal. APNS_KEY_P8 is the full PEM contents (BEGIN...END lines
# included). APNS_ENV selects the sandbox vs production APNS endpoint
# at process boot — redeploy to switch.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_KEY_P8=
APNS_ENV=sandbox

# --- Firebase Cloud Messaging (FCM) ---
# The Firebase service-account JSON credential. Download from
# Firebase console → Project Settings → Service accounts, paste the
# raw JSON as the value (single line — escape newlines or wrap in
# quotes per your env loader's rules). Missing creds = FCM publisher
# no-ops cleanly.
FCM_SERVICE_ACCOUNT_JSON=

# --- Mobile universal / app links ---
# iOS reuses APNS_BUNDLE_ID + APNS_TEAM_ID (declared in the APNS
# section above) — the identifiers are the same. Android needs its
# own package name + signing-cert fingerprint(s).
#
# ANDROID_SHA256_FINGERPRINTS accepts a comma-separated list so
# debug / release / Play App Signing certs can all verify the app's
# claim on this domain simultaneously. Each fingerprint is uppercase
# hex, colon-separated, e.g. "AA:BB:CC:DD:...:FF". Get release
# fingerprints from `keytool -list -v -keystore release.keystore`;
# Play App Signing fingerprints from Play Console →
# App integrity → App signing.
#
# When either var is unset, GET /.well-known/assetlinks.json returns
# 404 (no partial config).
ANDROID_PACKAGE_NAME=
ANDROID_SHA256_FINGERPRINTS=

# --- pgAdmin (docker-compose convenience only) ---
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=

# --- Frontend (CRA build-time, read by webpack not the API) ---
REACT_APP_S3_BUCKET=
REACT_APP_AWS_REGION_ENV=
REACT_APP_S3_BASE=
